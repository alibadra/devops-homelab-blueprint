# Domain — set this to your domain or local hostname
BASE_DOMAIN=lab.local

# Traefik
TRAEFIK_DASHBOARD_USER=admin
# htpasswd hash for password (generate: htpasswd -nb admin yourpassword)
TRAEFIK_DASHBOARD_PASSWORD_HASH=$$apr1$$...

# Portainer
PORTAINER_ADMIN_PASSWORD=changeme_portainer

# Gitea
GITEA_ADMIN_USER=gitadmin
GITEA_ADMIN_PASSWORD=changeme_gitea
GITEA_ADMIN_EMAIL=admin@lab.local
GITEA_DB_PASSWORD=changeme_giteadb

# Drone
DRONE_GITEA_CLIENT_ID=     # from Gitea OAuth app
DRONE_GITEA_CLIENT_SECRET= # from Gitea OAuth app
DRONE_RPC_SECRET=changeme_drone_rpc

# Vault
VAULT_DEV_ROOT_TOKEN_ID=  # leave empty for production mode

# Registry
REGISTRY_USER=admin
REGISTRY_PASSWORD=changeme_registry

# TZ
TZ=Europe/Brussels
